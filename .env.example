# ─────────────────────────────────────────────────────────
# TRIVIA — Environment Variables
# Copy this file to .env and fill in your Supabase values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────

# Supabase project URL (found in: Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (found in: Project Settings → API)
SUPABASE_KEY=your-anon-public-key-here

# Optional: Supabase service role key (server-side only, never expose to client)
# SUPABASE_SERVICE_KEY=your-service-role-key-here
